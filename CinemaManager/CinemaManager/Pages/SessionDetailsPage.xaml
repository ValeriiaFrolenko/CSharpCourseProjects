<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CinemaManager.Pages.SessionDetailsPage"
             Title="Session Details">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="{Binding Session.MovieName, FallbackValue='Loading...'}" 
                   Style="{StaticResource Headline}" />

            <Border Padding="20">
                <VerticalStackLayout Spacing="10">

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Start Time:" FontAttributes="Bold" />
                        <Label Text="{Binding Session.StartTime, StringFormat='{0:dd.MM.yyyy HH:mm}', FallbackValue='N/A'}" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="End Time:" FontAttributes="Bold" />
                        <Label Text="{Binding Session.EndTime, StringFormat='{0:dd.MM.yyyy HH:mm}', FallbackValue='N/A'}" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Duration (min):" FontAttributes="Bold" />
                        <Label Text="{Binding Session.DurationInMinutes, FallbackValue='N/A'}" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Genre:" FontAttributes="Bold" />
                        <Label Text="{Binding Session.FilmGenre, FallbackValue='N/A'}" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Year of Release:" FontAttributes="Bold" />
                        <Label Text="{Binding Session.YearOfRelease, FallbackValue='N/A'}" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>